<%- include('../partials/layout-top', { title, user, activeSection }) %>

<section class="header-row"><h1>Assigned Students</h1></section>

<section class="card">
  <h3>Students With Leave History</h3>
  <table>
    <thead><tr><th>ID</th><th>Name</th><th>Department</th><th>Semester</th><th>Total Leaves</th><th>Pending</th><th>Profile</th></tr></thead>
    <tbody>
      <% data.leaveStudents.forEach(s => { %>
        <tr>
          <td><%= s.student_id %></td>
          <td><%= s.name %></td>
          <td><%= s.department %></td>
          <td><%= s.semester %></td>
          <td><%= s.total_leaves %></td>
          <td><%= s.pending_count %></td>
          <td><a class="btn" href="/faculty/students/<%= s.student_id %>">View Details</a></td>
        </tr>
      <% }) %>
      <% if (data.leaveStudents.length === 0) { %>
        <tr><td colspan="7">No students with leave history.</td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<section class="card">
  <h3>Students Without Leave History</h3>
  <table>
    <thead><tr><th>ID</th><th>Name</th><th>Department</th><th>Semester</th><th>CGPA</th><th>Profile</th></tr></thead>
    <tbody>
      <% data.studentsNoLeaves.forEach(s => { %>
        <tr>
          <td><%= s.student_id %></td>
          <td><%= s.name %></td>
          <td><%= s.department %></td>
          <td><%= s.semester %></td>
          <td><%= s.cgpa_overall %></td>
          <td><a class="btn" href="/faculty/students/<%= s.student_id %>">View Details</a></td>
        </tr>
      <% }) %>
      <% if (data.studentsNoLeaves.length === 0) { %>
        <tr><td colspan="6">All assigned students have leave history.</td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<%- include('../partials/layout-bottom') %>