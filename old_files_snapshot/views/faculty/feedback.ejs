<%- include('../partials/layout-top', { title, user, activeSection }) %>

<%
  const recentFeedback = data.recentFeedback || [];
  const feedbackStudents = data.feedbackStudents || [];
  const studentsWithFeedback = feedbackStudents.filter((student) => Number(student.feedback_count || 0) > 0);
  const studentsWithoutFeedback = feedbackStudents.filter((student) => Number(student.feedback_count || 0) === 0);
%>

<section class="header-row"><h1>Faculty Feedback Center</h1></section>

<section class="grid cards-4">
  <div class="card">
    <h3>Total Feedback Notes</h3>
    <p><%= recentFeedback.length %></p>
  </div>
  <div class="card">
    <h3>Students Guided</h3>
    <p><%= studentsWithFeedback.length %></p>
  </div>
  <div class="card">
    <h3>Need First Feedback</h3>
    <p><%= studentsWithoutFeedback.length %></p>
  </div>
  <div class="card">
    <h3>Assigned Students</h3>
    <p><%= feedbackStudents.length %></p>
  </div>
</section>

<section class="grid cards-2">
  <section class="card faculty-monitor-card">
    <h3>Recent Feedback Sent</h3>
    <div class="faculty-monitor-list">
      <% recentFeedback.forEach((item) => { %>
        <article class="faculty-monitor-item">
          <div>
            <strong><%= item.student_name %></strong>
            <p><%= item.subject %> - Sem <%= item.semester %></p>
            <p><%= item.message %></p>
            <p>Shared on <%= new Date(item.created_at).toLocaleString() %></p>
          </div>
          <a class="btn" href="/faculty/students/<%= item.student_id %>">Open Student</a>
        </article>
      <% }) %>
      <% if (!recentFeedback.length) { %>
        <p class="faculty-monitor-empty">No feedback has been sent yet.</p>
      <% } %>
    </div>
  </section>

  <section class="card faculty-monitor-card">
    <h3>Student Feedback Coverage</h3>
    <div class="faculty-monitor-list">
      <% feedbackStudents.forEach((student) => { %>
        <article class="faculty-monitor-item faculty-monitor-item-compact">
          <div>
            <strong><%= student.student_name %></strong>
            <p><%= student.department %> - Sem <%= student.semester %></p>
            <p>
              <%= Number(student.feedback_count || 0) %> feedback note(s)
              <% if (student.latest_feedback_at) { %>
                - Last sent <%= new Date(student.latest_feedback_at).toLocaleString() %>
              <% } %>
            </p>
          </div>
          <a class="btn" href="/faculty/students/<%= student.student_id %>"><%= Number(student.feedback_count || 0) > 0 ? 'View History' : 'Send Feedback' %></a>
        </article>
      <% }) %>
      <% if (!feedbackStudents.length) { %>
        <p class="faculty-monitor-empty">No assigned students found.</p>
      <% } %>
    </div>
  </section>
</section>

<%- include('../partials/layout-bottom') %>
