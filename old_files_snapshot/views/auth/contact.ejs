<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | CIP</title>
  <link rel="stylesheet" href="/css/style.css" />
  <script defer src="/js/theme.js"></script>
</head>
<body class="landing-page page-contact">
  <header class="landing-nav-wrap">
    <nav class="landing-nav">
      <a class="brand-mark" href="/">
        <span class="brand-icon">&#127891;</span>
        <span><%= home.collegeName %></span>
      </a>
      <div class="landing-links">
        <a href="/">Home</a>
        <a href="/about-college">About</a>
        <a href="/departments">Departments</a>
        <a href="/faculty">Faculty</a>
        <a href="/placements">Placements</a>
        <a href="/login">Login</a>
        <a class="active" href="/contact">Contact</a>
        <span class="mode-icon">&#9789;</span>
      </div>
    </nav>
  </header>

  <main class="contact-screen">
    <section class="about-intro">
      <h1>Contact Us</h1>
      <p>We'd love to hear from you. Send us a message!</p>
    </section>

    <section class="contact-grid">
      <article class="contact-form-card">
        <form class="contact-form" action="#" method="POST">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" placeholder="Your name" />

          <label for="email">Email</label>
          <input id="email" name="email" type="email" placeholder="your@email.com" />

          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" placeholder="Your message..."></textarea>

          <button type="submit">Send Message</button>
        </form>
      </article>

      <article class="map-card">
        <iframe
          title="College Location"
          src="https://maps.google.com/maps?q=123%20College%20Road%2C%20City&t=&z=14&ie=UTF8&iwloc=&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </article>
    </section>

    <section class="contact-info-row">
      <p>&#128205; <%= home.contact.address %></p>
      <p>&#9742; <%= home.contact.phone %></p>
      <p>&#9993; <%= home.contact.email %></p>
    </section>
  </main>

  <footer class="landing-footer">
    <div class="footer-grid">
      <div>
        <h3><span class="brand-icon">&#127891;</span> <%= home.collegeName %></h3>
        <p>Empowering students with quality education since 1985. Shaping the leaders of tomorrow.</p>
      </div>
      <div>
        <h4>Quick Links</h4>
        <a href="/about-college">About Us</a>
        <a href="/departments">Departments</a>
        <a href="/faculty">Faculty</a>
        <a href="/placements">Placements</a>
        <a href="/contact">Contact</a>
      </div>
      <div>
        <h4>Contact</h4>
        <p>&#128205; <%= home.contact.address %></p>
        <p>&#9742; <%= home.contact.phone %></p>
        <p>&#9993; <%= home.contact.email %></p>
      </div>
      <div>
        <h4>Follow Us</h4>
        <p>Facebook</p>
        <p>Twitter</p>
        <p>Instagram</p>
        <p>LinkedIn</p>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; 2026 <%= home.collegeName %>. All rights reserved.
    </div>
  </footer>
</body>
</html>




