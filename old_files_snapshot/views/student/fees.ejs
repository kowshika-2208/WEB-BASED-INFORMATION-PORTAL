<%- include('../partials/layout-top', { title, user, activeSection }) %>

<section class="header-row"><h1>Fee Details</h1></section>

<section class="grid cards-3">
  <div class="card"><h3>Total Records</h3><p><%= data.fees.length %></p></div>
  <div class="card"><h3>Latest Semester</h3><p><%= data.fees.length ? data.fees[data.fees.length - 1].semester : 'N/A' %></p></div>
  <div class="card"><h3>Latest Status</h3><p><%= data.fees.length ? data.fees[data.fees.length - 1].status : 'N/A' %></p></div>
</section>

<section class="card">
  <h3>Semester Fee Status</h3>
  <table>
    <thead><tr><th>Semester</th><th>Amount</th><th>Status</th></tr></thead>
    <tbody>
      <% data.fees.forEach(row => { %>
        <tr><td><%= row.semester %></td><td><%= row.amount %></td><td><%= row.status %></td></tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('../partials/layout-bottom') %>