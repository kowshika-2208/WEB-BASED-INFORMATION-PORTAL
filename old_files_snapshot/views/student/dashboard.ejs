<script>
  (() => {
    const tabs = Array.from(document.querySelectorAll('.dashboard-tabs .dashboard-tab'));
    const panels = Array.from(document.querySelectorAll('.student-panel'));

    const activate = (hash) => {
      const target = (hash || '#profile').replace('#', '');
      tabs.forEach((tab) => {
        const href = tab.getAttribute('href') || '';
        const tabHash = href.includes('#') ? href.slice(href.indexOf('#') + 1) : '';
        tab.classList.toggle('active', tabHash === target);
      });
      panels.forEach((panel) => {
        panel.classList.toggle('active', panel.id === target);
      });

      if (target === 'result' && typeof buildLineChart === 'function') {
        setTimeout(() => buildLineChart('studentResultChart'), 0);
      }
    };

    activate(window.location.hash);
    window.addEventListener('hashchange', () => activate(window.location.hash));
  })();
</script>

<%- include('../partials/layout-bottom') %>
