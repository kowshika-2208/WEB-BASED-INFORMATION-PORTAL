<%- include('../partials/layout-top', { title, user, activeSection }) %>

<section class="header-row"><h1>Operations</h1></section>

<section class="grid cards-3">
  <div class="card">
    <h3>Assign Faculty to Student</h3>
    <form method="POST" action="/admin/assign-faculty" class="stack-form">
      <select name="student_id" required>
        <option value="">Select student</option>
        <% students.forEach(student => { %>
          <option value="<%= student.id %>">
            <%= student.name %> (ID: <%= student.id %>, Sem <%= student.semester %>, <%= student.department %>)
          </option>
        <% }) %>
      </select>
      <select name="faculty_id" required>
        <option value="">Select faculty</option>
        <% faculty.forEach(member => { %>
          <option value="<%= member.id %>">
            <%= member.name %> (ID: <%= member.id %>, <%= member.department %>)
          </option>
        <% }) %>
      </select>
      <button type="submit">Assign</button>
    </form>
  </div>
  <div class="card">
    <h3>Manage Fees</h3>
    <form method="POST" action="/admin/fees" class="stack-form">
      <input name="student_id" type="number" placeholder="Student ID" required />
      <input name="semester" type="number" min="1" max="12" placeholder="Semester" required />
      <input name="amount" type="number" min="0" placeholder="Amount" required />
      <select name="status"><option>Paid</option><option>Pending</option></select>
      <button type="submit">Save Fee</button>
    </form>
  </div>
  <div class="card">
    <h3>Manage Semester</h3>
    <form method="POST" action="/admin/semesters" class="stack-form">
      <input name="semester_number" type="number" min="1" max="12" placeholder="Semester Number" required />
      <input name="academic_year" placeholder="Academic Year (2025-2026)" required />
      <button type="submit">Save Semester</button>
    </form>
  </div>
</section>

<section class="card">
  <h3>Current Monitoring Assignments</h3>
  <table>
    <thead><tr><th>Student</th><th>Department</th><th>Semester</th><th>Monitoring Faculty</th></tr></thead>
    <tbody>
      <% students.forEach(student => { %>
        <tr>
          <td><%= student.name %> <span class="muted">(ID: <%= student.id %>)</span></td>
          <td><%= student.department %></td>
          <td><%= student.semester %></td>
          <td><%= student.faculty_name || 'Not assigned' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('../partials/layout-bottom') %>
